# Backend
PORT=4000
# comma-separated list of allowed frontend origins (for cookies/credentials)
CORS_ORIGINS=http://localhost:3000

# Database (STEP 3/4)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public&sslmode=disable

# Steam Web API (used to fetch Steam nickname/personaname during Steam OpenID callback)
STEAM_WEB_API_KEY=your_steam_web_api_key

# World’s Edge API
WORLDS_EDGE_API_BASE_URL=https://aoe-api.worldsedgelink.com/community/leaderboard
WORLDS_EDGE_API_TIMEOUT_MS=7000

# STEP 5 (Firestore import)
# Path to Firebase service account JSON (do NOT commit it)
GOOGLE_APPLICATION_CREDENTIALS=C:\absolute\path\to\firebase-service-account.json
# Firebase project id (e.g. "my-project")
FIREBASE_PROJECT_ID=your_firebase_project_id
