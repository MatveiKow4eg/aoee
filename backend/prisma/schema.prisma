generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MapState {
  id                String        @id @default(cuid())
  slug              String        @unique
  version           Int
  updatedAt         DateTime      @default(now()) @map("updated_at")
  worldW            Int           @map("world_w")
  worldH            Int           @map("world_h")
  mapTextureVersion Int           @default(1) @map("map_texture_version")
  metaJson          Json?         @map("meta_json")
  buildings         MapBuilding[]
  players           MapPlayer[]

  @@index([slug])
  @@map("map_states")
}

model MapBuilding {
  id          String   @id @default(cuid())
  mapStateId  String   @map("map_state_id")
  buildingKey String   @map("building_key")
  x           Float
  y           Float
  zoneX       Float    @map("zone_x")
  zoneY       Float    @map("zone_y")
  zoneW       Float    @map("zone_w")
  zoneH       Float    @map("zone_h")
  scale       Float?
  rotation    Float?
  proj0       Float?   @map("proj_0")
  proj1       Float?   @map("proj_1")
  proj2       Float?   @map("proj_2")
  proj3       Float?   @map("proj_3")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  mapState    MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  @@index([mapStateId, buildingKey])
  @@map("map_buildings")
}

model MapPlayer {
  id         String   @id @default(cuid())
  mapStateId String   @map("map_state_id")
  playerKey  String   @map("player_key")
  x          Float?
  y          Float?
  tier       String?
  name       String?
  title      String?
  desc       String?
  extraJson  Json?    @map("extra_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  mapState   MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  @@index([mapStateId, playerKey])
  @@map("map_players")
}

model User {
  id               String     @id @default(cuid())
  email            String?    @unique
  displayName      String?    @map("display_name")
  passwordHash     String?    @map("password_hash")
  role             String     @default("USER")
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  aoeLinkedAt      DateTime?  @map("aoe_linked_at")
  aoeNickname      String?    @map("aoe_nickname")
  aoeProfileId     String?    @map("aoe_profile_id")
  aoeProfileUrl    String?    @map("aoe_profile_url")
  accounts         Account[]
  aoePlayerClaimed AoePlayer? @relation("AoePlayerClaim")
  sessions         Session[]

  @@index([email])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  ip        String?
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model AoePlayer {
  id              String    @id @default(cuid())
  aoeProfileId    String    @unique @map("aoe_profile_id")
  aoeProfileUrl   String    @map("aoe_profile_url")
  nickname        String
  claimedByUserId String?   @unique @map("claimed_by_user_id")
  claimedAt       DateTime? @map("claimed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  claimedByUser   User?     @relation("AoePlayerClaim", fields: [claimedByUserId], references: [id])

  @@index([claimedByUserId])
  @@map("aoe_players")
}
