generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// STEP 3 foundation: map storage (Firestore maps/default -> Postgres)
model MapState {
  id                 String        @id @default(cuid())
  slug               String        @unique
  version            Int
  updatedAt          DateTime      @default(now()) @map("updated_at")

  // world
  worldW             Int           @map("world_w")
  worldH             Int           @map("world_h")
  mapTextureVersion  Int           @default(1) @map("map_texture_version")

  metaJson           Json?         @map("meta_json")

  buildings          MapBuilding[]
  players            MapPlayer[]

  @@map("map_states")
  @@index([slug])
}

model MapBuilding {
  id         String   @id @default(cuid())
  mapStateId String   @map("map_state_id")
  mapState   MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  buildingKey String  @map("building_key")

  x          Float
  y          Float
  zoneX      Float    @map("zone_x")
  zoneY      Float    @map("zone_y")
  zoneW      Float    @map("zone_w")
  zoneH      Float    @map("zone_h")

  scale      Float?
  rotation   Float?

  proj0      Float?   @map("proj_0")
  proj1      Float?   @map("proj_1")
  proj2      Float?   @map("proj_2")
  proj3      Float?   @map("proj_3")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("map_buildings")
  @@index([mapStateId, buildingKey])
}

model MapPlayer {
  id         String   @id @default(cuid())
  mapStateId String   @map("map_state_id")
  mapState   MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  playerKey  String   @map("player_key")

  x          Float?
  y          Float?
  tier       String?
  name       String?
  title      String?
  desc       String?

  extraJson  Json?    @map("extra_json")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("map_players")
  @@index([mapStateId, playerKey])
}

// STEP 7 foundation: credentials auth + sessions (cookie-based)
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  displayName  String?   @map("display_name")
  passwordHash String?   @map("password_hash")
  role         String    @default("USER")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Optional AoE2Insights profile link (auto-linked after Steam login when exact match is found)
  aoeProfileId  String?   @map("aoe_profile_id")
  aoeProfileUrl String?   @map("aoe_profile_url")
  aoeNickname   String?   @map("aoe_nickname")
  aoeLinkedAt   DateTime? @map("aoe_linked_at")

  sessions     Session[]
  accounts     Account[]

  // At most one AoE roster player can be claimed by this user
  aoePlayerClaimed AoePlayer? @relation("AoePlayerClaim")

  @@map("users")
  @@index([email])
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @map("token_hash")
  ip        String?
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")

  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@unique([tokenHash])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Linked auth providers (e.g., steam, credentials)
model Account {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider            String
  providerAccountId   String   @map("provider_account_id")

  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// AoE2Insights roster (pre-seeded) with atomic claim by users
model AoePlayer {
  id              String    @id @default(cuid())

  aoeProfileId    String    @unique @map("aoe_profile_id")
  aoeProfileUrl   String    @map("aoe_profile_url")
  nickname        String

  claimedByUserId String?   @unique @map("claimed_by_user_id")
  claimedByUser   User?     @relation("AoePlayerClaim", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  claimedAt       DateTime? @map("claimed_at")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([claimedByUserId])
  @@map("aoe_players")
}
