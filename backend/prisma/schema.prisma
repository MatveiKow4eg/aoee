generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MapState {
  id                String        @id @default(cuid())
  slug              String        @unique
  version           Int
  updatedAt         DateTime      @default(now()) @map("updated_at")
  worldW            Int           @map("world_w")
  worldH            Int           @map("world_h")
  mapTextureVersion Int           @default(1) @map("map_texture_version")
  metaJson          Json?         @map("meta_json")
  buildings         MapBuilding[]
  players           MapPlayer[]

  @@index([slug])
  @@map("map_states")
}

model MapBuilding {
  id          String   @id @default(cuid())
  mapStateId  String   @map("map_state_id")
  buildingKey String   @map("building_key")
  x           Float
  y           Float
  zoneX       Float    @map("zone_x")
  zoneY       Float    @map("zone_y")
  zoneW       Float    @map("zone_w")
  zoneH       Float    @map("zone_h")
  scale       Float?
  rotation    Float?
  proj0       Float?   @map("proj_0")
  proj1       Float?   @map("proj_1")
  proj2       Float?   @map("proj_2")
  proj3       Float?   @map("proj_3")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  mapState    MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  @@index([mapStateId, buildingKey])
  @@map("map_buildings")
}

model MapPlayer {
  id         String   @id @default(cuid())
  mapStateId String   @map("map_state_id")
  playerKey  String   @map("player_key")
  x          Float?
  y          Float?
  tier       String?
  name       String?
  title      String?
  desc       String?
  extraJson  Json?    @map("extra_json")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  mapState   MapState @relation(fields: [mapStateId], references: [id], onDelete: Cascade)

  @@index([mapStateId, playerKey])
  @@map("map_players")
}

model User {
  id                    String     @id @default(cuid())
  email                 String?    @unique
  displayName           String?    @map("display_name")
  passwordHash          String?    @map("password_hash")
  role                  String     @default("USER")
  isActive              Boolean    @default(true) @map("is_active")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")

  // Challenge rating points (separate from any other in-game currencies).
  ratingPoints          Int        @default(0) @map("rating_points")

  // Challenge cooldown applies ONLY to the challenger and starts AFTER resolution/expiry.
  challengeCooldownUntil DateTime? @map("challenge_cooldown_until")

  accounts              Account[]
  aoePlayerClaimed      AoePlayer? @relation("AoePlayerClaim")
  sessions              Session[]

  challengesAsChallenger UserChallenge[] @relation("ChallengeChallenger")
  challengesAsTarget     UserChallenge[] @relation("ChallengeTarget")
  challengesResolved     UserChallenge[] @relation("ChallengeResolvedBy")

  ratingEvents          UserRatingEvent[]

  // Optional link to playerKey-based profile (claimed/unclaimed map player identity)
  playerProfiles        PlayerProfile[]

  // Opposite side of PlayerProfile.claimedByUser relation
  claimedPlayerProfile  PlayerProfile? @relation("PlayerProfileClaim")

  // Admin-created match events
  matchEventsCreated    MatchEvent[]            @relation("MatchEventCreatedBy")
  matchEventsResolved   MatchEvent[]            @relation("MatchEventResolvedBy")
  matchEventParticipants MatchEventParticipant[]

  @@index([email])
  @@index([challengeCooldownUntil])
  @@index([ratingPoints])
  @@map("users")
}

model Session {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  ip        String?
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String
  providerAccountId String   @map("provider_account_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model AoePlayer {
  id              String                 @id @default(cuid())
  aoeProfileId    String                 @unique @map("aoe_profile_id")
  aoeProfileUrl   String                 @map("aoe_profile_url")
  nickname        String
  // New: link existing player/profile by SteamID (filled manually by admin)
  steamId         String?                @unique @map("steam_id")
  claimedByUserId String?                @unique @map("claimed_by_user_id")
  claimedAt       DateTime?              @map("claimed_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  claimedByUser   User?                  @relation("AoePlayerClaim", fields: [claimedByUserId], references: [id])
  statSnapshot    AoePlayerStatSnapshot?

  @@index([claimedByUserId])
  @@map("aoe_players")
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum ChallengeResult {
  CHALLENGER_WON
  CHALLENGER_LOST
  DRAW
  NO_SHOW
}

enum UserRatingEventReason {
  CHALLENGE_WIN
  CHALLENGE_LOSS
  ADMIN_ADJUST
}

enum PlayerRatingEventReason {
  CHALLENGE_WIN
  CHALLENGE_LOSS
  ADMIN_ADJUST
}

enum MatchEventFormat {
  ONE_V_ONE
  TWO_V_TWO
  THREE_V_THREE
  FOUR_V_FOUR
}

enum MatchEventStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum MatchEventSide {
  A
  B
}

enum MatchEventParticipantResult {
  WIN
  LOSS
}

model UserChallenge {
  id               String          @id @default(cuid())

  // Set when rating has been applied for this challenge to prevent double-processing.
  ratingAppliedAt  DateTime?       @map("rating_applied_at")

  // Player-key based identities (allow rating updates even when targetUserId is null)
  challengerPlayerKey String?      @map("challenger_player_key")
  winnerPlayerKey     String?      @map("winner_player_key")
  loserPlayerKey      String?      @map("loser_player_key")

  challengerUserId String          @map("challenger_user_id")
  targetUserId     String?         @map("target_user_id")

  // Optional target identifiers when the target user is not resolved/claimed yet.
  targetPlayerKey  String?         @map("target_player_key")
  targetAoeProfileId String?       @map("target_aoe_profile_id")

  status           ChallengeStatus @default(ACTIVE)
  result           ChallengeResult?

  createdAt        DateTime        @default(now()) @map("created_at")
  acceptedAt       DateTime        @map("accepted_at")
  expiresAt        DateTime        @map("expires_at")

  resolvedAt       DateTime?       @map("resolved_at")
  resolvedByUserId String?         @map("resolved_by_user_id")

  winnerUserId     String?         @map("winner_user_id")
  loserUserId      String?         @map("loser_user_id")

  notes            String?

  challengerUser   User            @relation("ChallengeChallenger", fields: [challengerUserId], references: [id], onDelete: Restrict)
  targetUser       User?           @relation("ChallengeTarget", fields: [targetUserId], references: [id], onDelete: Restrict)
  resolvedByUser   User?           @relation("ChallengeResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([challengerUserId])
  @@index([targetUserId])
  @@index([targetPlayerKey])
  @@index([targetAoeProfileId])
  @@index([status])
  @@index([expiresAt])
  ratingEvents     UserRatingEvent[]
  playerRatingEvents PlayerRatingEvent[]

  @@map("user_challenges")
}

model UserRatingEvent {
  id          String                @id @default(cuid())
  userId      String                @map("user_id")
  challengeId String?               @map("challenge_id")
  delta       Int
  reason      UserRatingEventReason
  createdAt   DateTime              @default(now()) @map("created_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   UserChallenge?         @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([challengeId])
  @@index([reason])
  @@index([createdAt])
  @@map("user_rating_events")
}

model PlayerProfile {
  id           String   @id @default(cuid())
  playerKey    String   @unique @map("player_key")
  aoeProfileId String?  @map("aoe_profile_id")

  // Optional claim link: when set, this profile is owned by a site user.
  // OR-identity rule: profile identity is ALWAYS playerKey; claim must never create a new profile.
  claimedByUserId String? @unique @map("claimed_by_user_id")

  // Legacy optional link (kept for backward compatibility; prefer claimedByUserId).
  userId       String?  @map("user_id")

  displayName  String?  @map("display_name")
  ratingPoints Int      @default(0) @map("rating_points")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  claimedByUser User?   @relation("PlayerProfileClaim", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ratingEvents PlayerRatingEvent[]

  @@index([aoeProfileId])
  @@index([claimedByUserId])
  @@index([userId])
  @@index([ratingPoints])
  @@map("player_profiles")
}

model PlayerRatingEvent {
  id          String                 @id @default(cuid())
  playerKey   String                 @map("player_key")
  challengeId String?                @map("challenge_id")
  delta       Int
  reason      PlayerRatingEventReason
  createdAt   DateTime               @default(now()) @map("created_at")

  player      PlayerProfile          @relation(fields: [playerKey], references: [playerKey], onDelete: Cascade)
  challenge   UserChallenge?         @relation(fields: [challengeId], references: [id], onDelete: SetNull)

  @@index([playerKey])
  @@index([challengeId])
  @@index([reason])
  @@index([createdAt])
  @@map("player_rating_events")
}

model MatchEvent {
  id              String           @id @default(cuid())
  format          MatchEventFormat
  status          MatchEventStatus @default(OPEN)
  winnerSide      MatchEventSide?  @map("winner_side")

  createdByUserId String           @map("created_by_user_id")
  resolvedByUserId String?         @map("resolved_by_user_id")

  ratingAppliedAt DateTime?        @map("rating_applied_at")

  notes           String?

  createdAt       DateTime         @default(now()) @map("created_at")
  resolvedAt      DateTime?        @map("resolved_at")

  createdByUser   User             @relation("MatchEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  resolvedByUser  User?            @relation("MatchEventResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  participants    MatchEventParticipant[]

  @@index([status, createdAt])
  @@index([createdByUserId])
  @@index([resolvedByUserId])
  @@map("match_events")
}

model MatchEventParticipant {
  id                 String                     @id @default(cuid())
  eventId            String                     @map("event_id")
  side               MatchEventSide
  slot               Int

  playerKey           String                    @map("player_key")
  userId              String?                   @map("user_id")
  aoeProfileId         String?                  @map("aoe_profile_id")

  displayNameSnapshot String                    @map("display_name_snapshot")
  avatarUrlSnapshot   String?                   @map("avatar_url_snapshot")

  result              MatchEventParticipantResult?
  ratingDelta         Int?                      @map("rating_delta")

  event               MatchEvent                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([eventId, side, slot])
  @@index([eventId])
  @@index([playerKey])
  @@index([userId])
  @@map("match_event_participants")
}

model AoePlayerStatSnapshot {
  id           String   @id @default(cuid())
  aoePlayerId  String   @unique @map("aoe_player_id")
  leaderboardId String? @map("leaderboard_id")
  rating       Int?
  rank         Int?
  rankTotal    Int?     @map("rank_total")
  wins         Int?
  losses       Int?
  streak       Int?
  syncedAt     DateTime @default(now()) @map("synced_at")

  aoePlayer    AoePlayer @relation(fields: [aoePlayerId], references: [id], onDelete: Cascade)

  @@index([syncedAt])
  @@map("aoe_player_stat_snapshots")
}
